set dotenv-load := true
set export := true
set shell := ["bash", "-lc"]

import '../shared.just'

# --- S3 Pod Identity Demo ---

_helm-values := "--set aws.region=$AWS_REGION --set bucket=$(just _bucket) --set s3files.fileSystemId=$(just _s3files-id)"

# S3 Pod Identity demo (MySQL → S3 → S3 Files mount → restore)
[group('eks')]
s3-test: _awslogin _eks-kubeconfig
    # Cleanup previous resources
    -kubectl delete job backup-to-s3 rclone-copy restore-from-s3 -n s3-test 2>/dev/null
    -helm uninstall s3-pod-identity -n s3-test 2>/dev/null

    @echo "Deploying MySQL with Pod Identity and AWS S3 Files CSI storage..."
    helm upgrade --install s3-pod-identity ../charts/s3-pod-identity -n s3-test --create-namespace {{ _helm-values }}
    kubectl wait --for=condition=Available deploy/mysql -n s3-test --timeout=120s
    -kubectl wait --for=condition=Complete job/sysbench-prepare -n s3-test --timeout=180s

    @echo "Backing up MySQL to S3..."
    helm template s3-pod-identity ../charts/s3-pod-identity {{ _helm-values }} --set jobs.backup=true --show-only templates/jobs/backup.yaml | kubectl apply -f -
    kubectl wait --for=condition=Complete job/backup-to-s3 -n s3-test --timeout=300s
    kubectl logs job/backup-to-s3 -n s3-test | tail -3

    @echo "Testing S3 Files CSI mount..."
    helm template s3-pod-identity ../charts/s3-pod-identity {{ _helm-values }} --set jobs.copy=true --show-only templates/jobs/copy.yaml | kubectl apply -f -
    kubectl wait --for=condition=Complete job/rclone-copy -n s3-test --timeout=120s
    kubectl logs job/rclone-copy -n s3-test
    kubectl wait --for=condition=Ready pod/debug -n s3-test --timeout=180s
    kubectl exec debug -n s3-test -- ls -la /mnt/s3

    @echo "S3 Pod Identity test complete ✓"
    @echo "Run 'just s3-pod-identity/s3-restore' to test restore, 'just s3-pod-identity/s3-cleanup' when done"

# Restore MySQL backup from S3
[group('eks')]
s3-restore: _eks-kubeconfig
    -kubectl delete job restore-from-s3 -n s3-test
    helm template s3-pod-identity ../charts/s3-pod-identity {{ _helm-values }} --set jobs.restore=true --show-only templates/jobs/restore.yaml | kubectl apply -f -
    kubectl wait --for=condition=Complete job/restore-from-s3 -n s3-test --timeout=300s
    kubectl logs job/restore-from-s3 -n s3-test -c mysqlsh-restore | tail -10

# Cleanup S3 Pod Identity resources
[group('eks')]
s3-cleanup:
    -kubectl delete job backup-to-s3 rclone-copy restore-from-s3 -n s3-test
    -helm uninstall s3-pod-identity -n s3-test
    -kubectl delete namespace s3-test
